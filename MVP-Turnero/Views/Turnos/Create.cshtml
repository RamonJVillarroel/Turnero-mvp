@model MVP_Turnero.Models.Turno

@{
    ViewData["Title"] = "Create";
}

<h1>Tomar Turno</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="ProfesionalId" class="control-label"></label>
                <input asp-for="Profesional.Usuario.Nombre" class="form-control" disabled />
                
            </div>
            <div class="form-group">
                <label asp-for="ClienteId" class="control-label">Cliente</label>
                
                <input asp-for="Cliente.Usuario.Nombre" class="form-control" disabled />
            </div>
            <div class="form-group">
                <label asp-for="TipoServicioId" class="control-label"></label>
                <select asp-for="TipoServicioId" class ="form-control" asp-items="ViewBag.TipoServicioId"></select>
            </div>
            <div class="form-group">
                <label asp-for="FechaHoraInicio" class="control-label"></label>
                <input asp-for="FechaHoraInicio" class="form-control" />
                <span asp-validation-for="FechaHoraInicio" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FechaHoraFin" class="control-label"></label>
                <input asp-for="FechaHoraFin" class="form-control" />
                <span asp-validation-for="FechaHoraFin" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
